# Copy this file to .env and fill in values for local development.
# Never commit .env — it is listed in .gitignore.
# Production secrets are stored in GCP Secret Manager, not here.

# ---------------------------------------------------------------------------
# GCP
# ---------------------------------------------------------------------------

# Project that hosts Secret Manager secrets, Cloud Run services, and Artifact Registry.
GCP_PROJECT_ID=your-gcp-project-id

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Deployment environment label written to every structured log line.
# Values: development | staging | production
ENVIRONMENT=development

# Logging verbosity.
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# ---------------------------------------------------------------------------
# Flask (local dev only — not used in Cloud Run)
# ---------------------------------------------------------------------------

FLASK_APP=main.py
FLASK_ENV=development

# Port the dev server listens on.  Cloud Run injects PORT automatically.
PORT=8080
